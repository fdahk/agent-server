# ==========================================================================
# .env.example — node-server 环境变量模板
# ==========================================================================
# 用法:cp .env.example .env,按本地情况改值(.env 已被 .gitignore 忽略)。
#
# 加载方式:@nestjs/config 的 ConfigModule.forRoot 在应用启动时读取本目录 .env
# 注入 process.env。容器部署不读 .env 文件,改由 docker-compose 的 environment 注入,
# 已存在的环境变量优先,二者不冲突。
#
# 本地开发推荐"混合模式":中间件(postgres/redis/milvus)在 docker 起,
# 业务(本服务)跑在宿主机,故下面各连接默认指向 localhost。
# ==========================================================================

# 运行环境:development / production / test
NODE_ENV=development
# HTTP 监听端口(避开其它本地服务)
PORT=3101

# ── 关系库(Prisma)──
# 宿主机连 docker 暴露的 postgres;凭据见 docker-compose 默认(agent/agent/agent_server)。
# 端口用 5433(偏移)避开 our-chat 的 5432,使两项目中间件可并行;
# 容器内部署不受影响(走 service 名 postgres:5432)。
DATABASE_URL=postgresql://agent:agent@localhost:5433/agent_server

# ── Redis(BullMQ 队列 + Pub/Sub backplane + 缓存)── 端口 6380 避开 our-chat 的 6379
REDIS_URL=redis://localhost:6380

# ── 向量库 Milvus ──
# 地址是 host:port(gRPC),不带 http;混合模式下连 docker 暴露的 milvus 19530
MILVUS_ADDRESS=localhost:19530
# 鉴权 token(用户名:密码);本地免鉴权留空
MILVUS_TOKEN=
MILVUS_COLLECTION=knowledge_chunks
# 向量维度:需与 LLM_EMBED_MODEL 输出维度一致(nomic-embed-text = 768)
MILVUS_VECTOR_SIZE=768

# ── LLM(OpenAI 兼容端点)──
# 本地默认指向宿主机 Ollama;生产改成厂商 BASE_URL + 真实 KEY
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_CHAT_MODEL=qwen2.5:7b
LLM_EMBED_MODEL=nomic-embed-text

# ── 鉴权 ──
# JWT_SECRET:本地签发兜底密钥(生产必须替换为足够长的随机串)
JWT_SECRET=dev-secret
# 签发 token 有效期(秒),默认 2 小时
JWT_EXPIRE_SECONDS=7200
# JWKS 验签:our-chat 是 IdP,本服务用其公钥验签其签发的 JWT(不自签发对外 token)
OAUTH_ISSUER=http://localhost:3007
OAUTH_JWKS_URI=http://localhost:3007/.well-known/jwks.json

# ── CORS 跨域白名单 ──
# 逗号分隔的精确 origin 列表;留空时:dev 反射任意 origin,生产拒绝所有跨源
CORS_ORIGINS=

# ── 文档摄取(RAG)──
# 单文件上限(字节),默认 10MB
DOCUMENT_MAX_BYTES=10485760
# 文档落盘目录(相对启动 cwd 或绝对路径)
DOCUMENT_STORAGE_DIR=./storage/documents
