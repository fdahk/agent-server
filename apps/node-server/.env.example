# ==========================================================================
# .env.example — Node AI Gateway 环境变量模板
# ==========================================================================
#
# 【使用方式】
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 根据你本地环境修改各项值
#   3. .env 文件已在 .gitignore 中，不会被提交到 Git（防止泄露密钥）
#
# 【环境变量 vs 硬编码】
#   把配置放在环境变量里而不是写死在代码里，有几个好处：
#     - 不同环境（开发/测试/生产）可以用不同的值
#     - 敏感信息（密钥、Token）不会出现在代码仓库中
#     - 部署时可以灵活调整，无需重新打包
# ==========================================================================

# 运行环境：development（开发）/ production（生产）/ test（测试）
# NestJS 和很多库会根据这个值切换行为（如是否输出调试日志）
NODE_ENV=development

# Node 服务监听的端口号（默认 3101，避免和 Java Core 的 3000 端口冲突）
PORT=3101

# ------ 内部认证 ------
# Java Core 调用 Node 时，在 HTTP Header 中带 X-Internal-Token 字段
# Node 端的 InternalTokenGuard 会验证这个值是否匹配
# ⚠️ 生产环境务必改成一个足够长的随机字符串！
INTERNAL_TOKEN=change-me-to-a-secure-token

# ------ Ollama / LLM 配置 ------
# Ollama 是一个本地运行大语言模型的工具（类似本地版 ChatGPT）
# base-url：Ollama 服务的 API 地址，默认在 11434 端口
OLLAMA_BASE_URL=http://localhost:11434
# 默认使用的模型名称（需要先在 Ollama 中 pull 下载对应模型）
OLLAMA_MODEL=qwen2.5:7b
# AI 调用超时（毫秒），模型推理可能较慢，给足时间
OLLAMA_HTTP_TIMEOUT_MS=120000

# ------ Agent 运行时配置 ------
# Agent 产物输出目录（报告文件等）
AGENT_OUTPUT_ROOT=./storage/agent-runs
# 单次运行最多采集的文件数量（防止目录过大导致内存溢出）
AGENT_MAX_FILES=12
# 单个文件最大字节数（256KB = 262144 字节），超过的文件会被跳过
AGENT_MAX_FILE_SIZE=262144
# 所有文件总字节数上限（2MB = 2097152 字节）
AGENT_MAX_TOTAL_BYTES=2097152
# 单个资源送入 AI 的最大字符数（超过会截断，避免 Token 超限）
AGENT_MAX_RESOURCE_CHARS=12000

# ------ HTTP 客户端配置 ------
# 通用 HTTP 请求超时（抓取网页等）
HTTP_CLIENT_TIMEOUT_MS=30000
# Agent 相关的 HTTP 超时（如资源采集的网页请求）
AGENT_HTTP_TIMEOUT_MS=30000

# ------ JWT / OAuth 跨服务鉴权 ------
# 现有 /auth/login 签发的本地 HS256 token 共享密钥(开发兜底)
JWT_SECRET=dev-secret

# 当 OAUTH_JWKS_URI 配置时,启用 RS256 + JWKS 验签路径
# our-chat IdP 的 JWKS 端点 URL(参考 our-chat/server/docs/oauth/07-集成指南-agent-server.md)
OAUTH_JWKS_URI=http://localhost:3007/.well-known/jwks.json
# OAuth issuer,必须与 our-chat 后端的 OAUTH_ISSUER_BASE_URL 一致
OAUTH_ISSUER=http://localhost:3007
