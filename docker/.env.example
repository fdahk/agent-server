# agent-server 部署/编排环境变量(docker compose 单一配置源)。
# 复制为 docker/.env(已被 .gitignore 忽略),按需覆盖。
#
# 两种用途:
#   1) compose 内 ${VAR} 替换(端口/镜像/凭据)—— 在 docker/ 下执行自动加载本文件;
#   2) env_file 整体注入 node-server / node-worker 容器(进程读 process.env)。
#
# 连接串用 docker 网络主机名(postgres/redis/milvus),勿改成 localhost。
# 宿主机直跑(make dev)不读本文件,见 apps/node-server/.env.example。

# ── 对外端口(仅 node-server API 暴露到宿主机)──
NODE_PORT=3101

# ── Postgres ──
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent_server

# ── Milvus 对象存储(MinIO,dev)── 生产把 docker-compose.yml 里 milvus 的 MINIO_* 指向腾讯 COS
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── 容器内连接串(docker 网络主机名)──
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent_server
REDIS_URL=redis://redis:6379
MILVUS_ADDRESS=milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=knowledge_chunks
# 向量维度:需与 LLM_EMBED_MODEL 输出维度一致(nomic-embed-text = 768)
MILVUS_VECTOR_SIZE=768

# ── LLM(OpenAI 兼容)── 容器默认指向宿主机 Ollama;生产改 BASE_URL/KEY 切第三方 API
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_CHAT_MODEL=qwen2.5:7b
LLM_EMBED_MODEL=nomic-embed-text

# ── 鉴权 ──
# JWT_SECRET:本地兜底密钥(生产必须替换为足够长随机串:openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRE_SECONDS=7200
# JWKS 验签:our-chat 是 IdP,本服务用其公钥验签(容器内经 host.docker.internal 访问宿主机 our-chat)
OAUTH_ISSUER=http://host.docker.internal:3007
OAUTH_JWKS_URI=http://host.docker.internal:3007/.well-known/jwks.json

# ── CORS 跨域白名单 ── 逗号分隔精确 origin;留空时 dev 反射任意 origin、生产拒绝所有跨源
CORS_ORIGINS=

# ── 文档摄取(RAG)──
DOCUMENT_MAX_BYTES=10485760
DOCUMENT_STORAGE_DIR=/app/storage/documents

# ── Agent ──
AGENT_OUTPUT_ROOT=/app/storage/agent-runs
AGENT_MAX_FILES=12
AGENT_MAX_FILE_SIZE=262144
AGENT_MAX_TOTAL_BYTES=2097152
AGENT_MAX_RESOURCE_CHARS=12000
HTTP_CLIENT_TIMEOUT_MS=30000
AGENT_HTTP_TIMEOUT_MS=30000
