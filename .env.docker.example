# 使用方式：cp .env.docker.example .env.docker
# 启动命令：docker compose --env-file .env.docker up -d
# ==========================================================================

# ==================== 基础设施端口 ====================
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ==================== 应用服务端口 ====================
NODE_PORT=3101

# ==================== Postgres ====================
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent_server

# ==================== Redis ====================
# 留空表示不设密码（开发环境可接受，生产环境务必设置）
REDIS_PASSWORD=

# ==================== 安全 ====================
# 旧 Java↔Node 内部令牌,node-server 现有 guard 仍引用,待 M0 重构清理
INTERNAL_TOKEN=change-me-to-a-secure-token

# ==================== LLM(OpenAI 兼容,详见 docs/01 §7)====================
# 本地开发指向宿主机 Ollama 的 OpenAI 兼容端点;生产改 BASE_URL/KEY 切第三方 API
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_CHAT_MODEL=qwen2.5:7b
LLM_EMBED_MODEL=nomic-embed-text

# ==================== Agent ====================
AGENT_MAX_FILES=12
AGENT_MAX_FILE_SIZE=262144
AGENT_MAX_TOTAL_BYTES=2097152
AGENT_MAX_RESOURCE_CHARS=12000
HTTP_CLIENT_TIMEOUT_MS=30000
AGENT_HTTP_TIMEOUT_MS=30000
