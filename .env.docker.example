# 使用方式：cp .env.docker.example .env.docker
# 启动命令：docker compose --env-file .env.docker up -d
# ==========================================================================

# ==================== 基础设施端口 ====================
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ==================== 应用服务端口 ====================
JAVA_PORT=3000
NODE_PORT=3101

# ==================== MySQL ====================
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=agent_server

# ==================== Redis ====================
# 留空表示不设密码（开发环境可接受，生产环境务必设置）
REDIS_PASSWORD=

# ==================== RabbitMQ ====================
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ==================== 安全 ====================
# Java ↔ Node 内部通信令牌（两端必须一致）
INTERNAL_TOKEN=change-me-to-a-secure-token
# JWT 签名密钥（生产环境务必换成随机长字符串）
JWT_SECRET=change-me-to-a-long-dev-secret-key-change-me
JWT_EXPIRE_SECONDS=7200

# ==================== AI ====================
# Ollama 跑在宿主机上，容器内通过 host.docker.internal 访问
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HTTP_TIMEOUT_MS=120000
AI_GATEWAY_TIMEOUT_MS=120000

# ==================== Agent ====================
AGENT_MAX_FILES=12
AGENT_MAX_FILE_SIZE=262144
AGENT_MAX_TOTAL_BYTES=2097152
AGENT_MAX_RESOURCE_CHARS=12000
HTTP_CLIENT_TIMEOUT_MS=30000
AGENT_HTTP_TIMEOUT_MS=30000
