# 使用方式：cp .env.docker.example .env.docker
# 启动命令：docker compose --env-file .env.docker up -d
# ==========================================================================

# ==================== 基础设施端口 ====================
REDIS_PORT=6379

# ==================== 应用服务端口 ====================
NODE_PORT=3101

# ==================== Redis ====================
# 留空表示不设密码（开发环境可接受，生产环境务必设置）
REDIS_PASSWORD=

# ==================== 安全 ====================
# 旧 Java↔Node 内部令牌,node-server 现有 guard 仍引用,待 M0 重构清理
INTERNAL_TOKEN=change-me-to-a-secure-token

# ==================== AI ====================
# Ollama 跑在宿主机上，容器内通过 host.docker.internal 访问
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HTTP_TIMEOUT_MS=120000

# ==================== Agent ====================
AGENT_MAX_FILES=12
AGENT_MAX_FILE_SIZE=262144
AGENT_MAX_TOTAL_BYTES=2097152
AGENT_MAX_RESOURCE_CHARS=12000
HTTP_CLIENT_TIMEOUT_MS=30000
AGENT_HTTP_TIMEOUT_MS=30000
